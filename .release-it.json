{
  "$schema": "https://unpkg.com/release-it@17/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "SID OS v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "SID OS v${version}",
    "autoGenerate": true
  },
  "npm": false,
  "hooks": {
    "before:init": ["echo 'Building SID OS v${version}...'"],
    "after:release": ["echo '✅ SID OS v${version} released!'"]
  }
}
